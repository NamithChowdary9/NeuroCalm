# MongoDB Atlas
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/neurocalm?retryWrites=true&w=majority
MONGO_DB=neurocalm

# App
APP_ENV=production
SECRET_KEY=your-secret-key-change-in-production

# CORS — set this to your Vercel frontend URL after deploying
FRONTEND_ORIGIN=https://your-app.vercel.app
# Or comma-separated for multiple origins:
ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:3000

# Optional: Ollama LLM (not needed on Railway unless self-hosted)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral
